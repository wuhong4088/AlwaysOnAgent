# Environment Variables — Cook Smart Backend (MVP)

PORT=4000
NODE_ENV=development

# JWT Secret (required for auth)
JWT_SECRET=replace_me

# OpenAI API Key (leave empty to use mock data fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Instacart redirect base URL
INSTACART_BASE_URL=https://www.instacart.com/store/search
